# ------------------------------------------------------------
# Midnight ignore rules
# Keep source, assets, maps, shaders, and CMake files tracked.
# Ignore generated build output, local tool state, logs, captures,
# cooked assets, and temporary files.
# ------------------------------------------------------------

# Build directories
/build/
/build-*/
/cmake-build-*/

# Accidental in-source CMake output
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
Testing/
Makefile

# Ninja / build tool state
.ninja_deps
.ninja_log
*.ninja

# Compilation database
# Generated by CMake. We can make a local symlink later for editors.
compile_commands.json

# Compiled objects / libraries / binaries
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# If someone accidentally builds the executable in the project root
/midnight

# Generated shader output
*.spv

# Future cooked/package output
/assets_cooked/
/dist/
/package/

# Runtime logs, dumps, profiler output, captures
*.log
*.dmp
core
core.*
perf.data*
*.trace
*.tracy
*.rdc

# Local editor/tool state
.cache/
.vscode/
.idea/
*.swp
*.swo
*~
CMakeUserPresets.json

# OS junk
.DS_Store
Thumbs.db

# Temporary local work areas
/incoming/
/downloads/
/scratch/
/_context/
